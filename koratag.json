  "news": [
    {
      "id": "n1",
      "title": "مبابي يرد على جماهير ريال مدريد بعد موجة الانتقادات",
      "image": "https://i.imgur.com/5iFqWEg.jpg",
      "time_ago": "منذ ساعة",
      "url": "",
      "content": "أصدر النجم الفرنسي كيليان مبابي بياناً رسمياً عبر حساباته على مواقع التواصل الاجتماعي، رداً على الانتقادات التي تعرض لها من جماهير ريال مدريد خلال الفترة الأخيرة."
    },
    {
      "id": "n2",
      "title": "محمد صلاح يحطم رقماً قياسياً جديداً في الدوري الإنجليزي",
      "image": "https://i.imgur.com/8QqZfGJ.png",
      "time_ago": "منذ ساعتين",
      "url": "",
      "content": "حطم النجم المصري محمد صلاح رقماً قياسياً تاريخياً في الدوري الإنجليزي الممتاز بتسجيله الهدف رقم 160 مع نادي ليفربول."
    },
    {
      "id": "n3",
      "title": "الأهلي يفوز بديربي القرن على الزمالك 3-1",
      "image": "https://i.imgur.com/5iFqWEg.jpg",
      "time_ago": "منذ 3 ساعات",
      "url": "",
      "content": "حقق النادي الأهلي المصري فوزاً كبيراً على غريمه الزمالك في نسخة جديدة من ديربي القرن بنتيجة 3-1."
    },
    {
      "id": "n4",
      "title": "ريال مدريد يضم نجماً برازيلياً شاباً في صفقة مفاجئة",
      "image": "https://i.imgur.com/8QqZfGJ.png",
      "time_ago": "منذ 4 ساعات",
      "url": "",
      "content": "أعلن نادي ريال مدريد الإسباني رسمياً عن التعاقد مع أحد أبرز المواهب البرازيلية الشابة في صفقة انتقال مفاجئة."
    },
    {
      "id": "n5",
      "title": "الاتحاد السعودي يعلن موعد انطلاق موسم 2026-2027",
      "image": "https://i.imgur.com/5iFqWEg.jpg",
      "time_ago": "منذ 5 ساعات",
      "url": "",
      "content": "أعلن الاتحاد السعودي لكرة القدم رسمياً عن موعد انطلاق الموسم الجديد من دوري روشن السعودي للمحترفين."
    },
    {
      "id": "n6",
      "title": "برشلونة يتعاقد مع حارس مرمى جديد قبل موسم الكلاسيكو",
